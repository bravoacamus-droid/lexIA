# ════════════════════════════════════════════════════
# SUPABASE
# ════════════════════════════════════════════════════
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Management API (solo para scripts de migraciones / seed; no usar en runtime de Vercel)
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=

# ════════════════════════════════════════════════════
# GEMINI (Google AI) — chat + embeddings
# ════════════════════════════════════════════════════
GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_PROJECT_ID=

# ════════════════════════════════════════════════════
# VOYAGE AI (no se usa por ahora — embeddings se generan con Gemini)
# ════════════════════════════════════════════════════
# VOYAGE_API_KEY=

# ════════════════════════════════════════════════════
# APP
# ════════════════════════════════════════════════════
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Lista separada por comas de emails con acceso. Vacío = todos los emails permitidos.
DEMO_ALLOWED_EMAILS=
